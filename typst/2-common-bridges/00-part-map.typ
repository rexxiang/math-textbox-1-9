// 共通桥梁 — 知识地图
#import "../lib/theme-v2.typ": side-hack

这一部分连接公共基础和后面的四条分支（代数、几何、函数、数据）。每一章引入一项"共用工具"，分支里都会反复用到。全部读完后，最后一章给出正式的"入口合同"——检验你是否准备好进入各分支。

#table(
  columns: (auto, 1fr, auto, auto),
  align: (center, left, center, center),
  stroke: 0.4pt,
  inset: 8pt,
  table.header([*章*], [*主题*], [*难度*], [*性质*]),
  [2.1], [比、比例与百分数], [★★★☆☆], [核心],
  [2.2], [数轴、负数与有理数], [★★★☆☆], [核心],
  [2.3], [坐标、位置与平面表示], [★★★☆☆], [核心],
  [2.4], [字母、代数式与"关系模板"], [★★★☆☆], [核心],
  [2.5], [方程、平衡与反向操作], [★★★☆☆], [核心],
  [2.6], [平方、平方根、无理数与数轴补完整], [★★★★☆], [核心],
  [2.7], [共通桥梁总检：四条分支的入口合同], [★★★☆☆], [总检],
)

#side-hack[
  *阅读建议*：2.1–2.6 按顺序读。读完全部后做 2.7 的入口合同——它会告诉你哪条分支已经可以开始、哪些地方需要回头补。四条分支之间没有先后依赖，可以选任意一条先走。
]
