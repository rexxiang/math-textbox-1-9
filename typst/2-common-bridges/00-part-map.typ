  [2.5], [方程、平衡与反向操作], [★★★☆☆], [核心],
  [2.6], [平方、平方根、无理数与数轴补完整], [★★★★☆], [核心],
  [2.7], [共通桥梁总检：四条分支的入口合同], [★★★☆☆], [总检],
)

#side-hack[
  *阅读建议*：2.1–2.6 按顺序读。读完全部后做 2.7 的入口合同——它会告诉你哪条分支已经可以开始、哪些地方需要回头补。四条分支之间没有先后依赖，可以选任意一条先走。
]
