    line((7, -0.2), (7, 1.8), stroke: (paint: gray, thickness: 0.5pt, dash: "dashed"))
    content((7, 2.0), text(6pt)[对称轴])
    // Reflected triangle
    let A4 = (9, 0)
    let B4 = (7.8, 0)
