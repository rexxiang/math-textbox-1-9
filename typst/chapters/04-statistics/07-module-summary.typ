=== 核心公式汇总

#align(center)[
#table(
  columns: 2, stroke: 0.5pt, inset: 6pt,
  [公式], [内容],
  [平均数], [平均数 = (x_1 + x_2 + … + x_n) / n],
  [加权平均数], [加权平均数 = x_1 w_1 + x_2 w_2 + … + x_n w_n（权重和为 1）],
  [极差], [最大值 - 最小值],
  [方差], [方差 = ((x_1 - 平均数)^2 + … + (x_n - 平均数)^2) / n],
  [频率], [频次 / 数据总个数],
  [等可能事件概率], [概率 = 有利结果数 / 全部结果数],
  [对立事件], [对立事件的概率 = 1 - P(A)],
)
]

