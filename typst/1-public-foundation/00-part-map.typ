// 公共基础 — 知识地图
#import "../lib/theme-v2.typ": side-hack

这一部分为全书打基础：从数数开始，逐步建立数、量、形三条主线，最终汇入一次总检。每一章只依赖前面的章，按顺序读即可。

#table(
  columns: (auto, 1fr, auto, auto),
  align: (center, left, center, center),
  stroke: 0.4pt,
  inset: 8pt,
  table.header([*章*], [*主题*], [*难度*], [*性质*]),
  [1.1], [数与位值：从"多少个"到十进制], [★☆☆☆☆], [核心],
  [1.2], [四则与运算结构：加减乘除、顺序与运算律], [★☆☆☆☆], [核心],
  [1.3], [因数、倍数、整除与质因数分解], [★★☆☆☆], [核心],
  [1.4], [分数：意义、等值、比较与运算], [★★☆☆☆], [核心],
  [1.5], [小数、单位、估算与测量], [★★☆☆☆], [核心],
  [1.6], [点、线、面与基本图形], [★☆☆☆☆], [核心],
  [1.7], [周长、面积、体积与角], [★★☆☆☆], [核心],
  [1.8], [平行、三角形与基础几何关系], [★★☆☆☆], [核心],
  [1.9], [公共基础总检：准备进入桥梁], [★★☆☆☆], [总检],
)

#side-hack[
  *阅读建议*：1.1–1.5 是数与量的主线，1.6–1.8 是形与空间的主线。两条线可以交替读，但 1.9 总检需要两条线全部完成后再做。
]
