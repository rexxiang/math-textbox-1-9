// 几何与证明 — 知识地图
#import "../lib/theme-v2.typ": side-hack

这一部分从全等判定开始，逐步走向相似、圆、勾股定理和三角比，最后用变换与坐标几何串联全局。核心能力是"写出完整的几何证明"。

#table(
  columns: (auto, 1fr, auto, auto),
  align: (center, left, center, center),
  stroke: 0.4pt,
  inset: 8pt,
  table.header([*章*], [*主题*], [*难度*], [*性质*]),
  [4.1], [全等与基本判定], [★★★★☆], [核心],
  [4.2], [判定深化与证明书写], [★★★★☆], [核心],
  [4.3], [相似、比例尺与平行线几何], [★★★★☆], [核心],
  [4.4], [四边形家族], [★★★★☆], [核心],
  [4.5], [圆与内接外切], [★★★★☆], [核心],
  [4.6], [勾股、根式度量与三角比], [★★★★★], [核心],
  [4.7], [变换、坐标几何与视图], [★★★★☆], [核心],
  [4.8], [几何总结], [★★★★☆], [总结],
)

#side-hack[
  *阅读建议*：4.1–4.2 是全等判定与证明书写的核心入门，必须先过。4.3 继续发展相似。4.4 和 4.5 可以交替读（四边形性质和圆相互独立），但 4.6 的勾股需要 4.5 的圆作前置。4.7 的坐标几何需要前面全部完成。
]
